# Django
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.dev

# PostgreSQL
POSTGRES_DB=cloudvault
POSTGRES_USER=cloudvault
POSTGRES_PASSWORD=cloudvault_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=cloudvault_redis
REDIS_URL=redis://:cloudvault_redis@redis:6379/0

# Celery
CELERY_BROKER_URL=redis://:cloudvault_redis@redis:6379/1
CELERY_RESULT_BACKEND=redis://:cloudvault_redis@redis:6379/2

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=cloudvault_minio
MINIO_ROOT_PASSWORD=cloudvault_minio_secret
MINIO_ACCESS_KEY=cloudvault_minio
MINIO_SECRET_KEY=cloudvault_minio_secret
MINIO_BUCKET_NAME=cloudvault-files
MINIO_USE_SSL=False
MINIO_EXTERNAL_URL=http://localhost:9000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Storage Quota (bytes)
DEFAULT_STORAGE_QUOTA=5368709120

# Trash retention (days)
TRASH_RETENTION_DAYS=30

# Max upload size (bytes) - 500MB
MAX_UPLOAD_SIZE=524288000

# Frontend
REACT_APP_API_URL=http://localhost:8000/api

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost
